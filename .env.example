# Platform — copy to .env.dev or .env.prod and fill real values
# NEVER commit .env.dev or .env.prod

PLATFORM_NAME=mock-test-platform
DEFAULT_LANG=hi
DEFAULT_NEG_MARKS=0.33
MAX_ATTEMPTS=3
SUPPORT_EMAIL=help@mock-test-platform.com

# Database (PgBouncer)
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_POOL_SIZE=20

# Cloudflare
CF_ACCOUNT_ID=
CF_API_TOKEN=
R2_BUCKET_PRIMARY=
R2_BUCKET_BACKUP=
KV_NAMESPACE_ID=

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PARAMETER_STORE_PREFIX=/mock-test-platform/

# Auth
JWT_SECRET=
JWT_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# Monitoring
GRAFANA_URL=
LOKI_URL=
PROMETHEUS_URL=
